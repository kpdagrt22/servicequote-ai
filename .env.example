# ---------------------------------------------------------------------------
# ServiceQuote AI — environment variables
# Copy this file to .env.local and fill in the values you have.
# Everything except the Supabase keys is OPTIONAL — the app degrades to mock
# providers and on-screen setup instructions when keys are missing.
# ---------------------------------------------------------------------------

# Supabase (required for auth + database)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider abstraction: mock | openai | anthropic
# When unset or "mock", the deterministic mock provider is used (no API key needed).
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional model overrides
AI_OPENAI_MODEL=gpt-4o-mini
AI_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Resend (optional — transactional email). Leave blank to log emails to the console.
RESEND_API_KEY=
RESEND_FROM_EMAIL=ServiceQuote AI <hello@example.com>

# Stripe (optional — billing). Leave blank to show "Billing not configured".
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_SETUP=

# Internal admin access. Comma-separated list of emails allowed into /admin.
# Organization owners also have admin access by role.
ADMIN_EMAILS=

# Observability (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
# Server-only error sink — Sentry tunnel, Slack/Discord webhook, or any JSON
# endpoint. When set, captureError() forwards sanitized errors here best-effort.
ERROR_WEBHOOK_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
